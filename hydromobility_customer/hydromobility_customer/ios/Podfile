require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# ✅ Set proper platform version (RN 0.77+ supports iOS 13+)
platform :ios, min_ios_version_supported


# ✅ Required for newer RN/Firebase/Stripe/Notifee compatibility
use_frameworks! :linkage => :static
use_modular_headers!

prepare_react_native_project!

require_relative '../node_modules/react-native/scripts/react_native_pods'

target 'hydromobility_customer' do
  config = use_native_modules!

  rn_maps_path = '../node_modules/react-native-maps'
  pod 'react-native-maps/Google', :path => rn_maps_path

  # ✅ Firebase pods (no need for 'Firebase/Core' in newer Firebase)
  pod 'RNFBApp', :path => '../node_modules/@react-native-firebase/app'
  pod 'RNFBDatabase', :path => '../node_modules/@react-native-firebase/database'
  pod 'RNFBMessaging', :path => '../node_modules/@react-native-firebase/messaging'
  pod 'MapLibre'
  # ✅ Standard React Native pod setup
  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # ✅ Post-install hooks
  post_install do |installer|
    # React Native MapLibre RN hook
    $MLRN.post_install(installer)

    # React Native core post-install
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end
